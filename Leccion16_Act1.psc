Algoritmo sin_titulo
	Definir n Como Entero
	Definir colores Como Caracter
	Dimensionar colores[8]
	
	colores[8]="Amarillo"
	colores[7]="Naranja"
	colores[6]="rojo"
	colores[5]="Morado"
	colores[4]="Azul"
	colores[3]="Verde"
	colores[2]="Marron"
	colores[1]="Negro"
	Escribir Sin Saltar"Dame un numero del 1 al 8: "
	leer n
	Escribir "El color de la casilla es el: ", colores[n]
	
FinAlgoritmo
